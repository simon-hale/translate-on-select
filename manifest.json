{
  "name": "Translate-on-select",
  "description": "This is a Chrome Extension that you can translate the phrase or the sentance what you select on the page.",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "menu/menu.html",
    "default_icon": "icons/icon_128.png"
  },
  "permissions": [
    "storage"
  ],
  "options_page": "options/options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["front/contentScript.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon_16.png",
    "32": "icons/icon_32.png",
    "48": "icons/icon_48.png",
    "128": "icons/icon_128.png"
  }
}